<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login — ShopEase</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>

  <nav>
    <a class="nav-logo" href="/">ShopEase</a>
    <a class="nav-link" href="/signup">Create account →</a>
  </nav>

  <div class="page">
    <div class="wrapper">

      <div class="left-panel">
        <h2>Good to see you again</h2>
        <p>Sign in to browse our handpicked collection and manage your cart.</p>
        <ul class="features">
          <li>Fast & secure checkout</li>
          <li>Track your orders easily</li>
          <li>Exclusive deals for members</li>
          <li>Save items to your cart</li>
        </ul>
      </div>

      <div class="right-panel">
        <div class="form-title">Sign in</div>
        <div class="form-sub">Welcome back! Enter your details below.</div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="error-msg"><%= error %></div>
        <% } %>

        <form action="/login" method="POST">
          <div class="input-group">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="input-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" placeholder="••••••••" required />
          </div>
          <button type="submit" class="submit-btn green">Sign in</button>
        </form>

        <div class="divider">
          <div class="divider-line"></div>
          <span class="divider-text">or</span>
          <div class="divider-line"></div>
        </div>

        <div class="form-footer">
          Don't have an account? <a href="/signup">Sign up for free</a>
        </div>
      </div>

    </div>
  </div>

</body>
</html>